DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/flyos?schema=public"
JWT_SECRET="change-me-in-production"

# Outside NODE_ENV=production, auth bypass is ON by default (no JWT for demo UI).
# Opt out: FLYOS_STRICT_AUTH=true or FLYOS_DEV_MODE=false
# FLYOS_STRICT_AUTH=false
# FLYOS_DEV_MODE=

# If the DB has no users at startup, one DISPATCHER is created (dev bypass only):
# FLYOS_DEV_SEED_EMAIL=dev@flyos.local
# FLYOS_DEV_SEED_PASSWORD=flyosdev

# Optional: impersonate this user for userId on mutations; RBAC uses FLYOS_DEV_USER_ROLE.
# FLYOS_DEV_USER_ID=
# FLYOS_DEV_USER_ROLE=DISPATCHER
