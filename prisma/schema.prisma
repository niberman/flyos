// ==========================================================================
// Prisma Schema — FlyOS Flight School Management System
// ==========================================================================
// Multi-tenant: TenantMiddleware injects organizationId / base scoping.
// Bookings target SchedulableResource; aircraft link via optional aircraftId.
// ==========================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------------------------
// Enums
// --------------------------------------------------------------------------

enum Role {
  STUDENT
  INSTRUCTOR
  DISPATCHER
}

enum AirworthinessStatus {
  FLIGHT_READY
  GROUNDED
}

enum SchedulableResourceKind {
  AIRCRAFT
  SIMULATOR
  CLASSROOM
}

enum BookingStatus {
  SCHEDULED
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingParticipantRole {
  RENTER
  INSTRUCTOR
}

enum SquawkStatus {
  OPEN
  DEFERRED
  CLEARED
}

// --------------------------------------------------------------------------
// Models
// --------------------------------------------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  bases                Base[]
  aircraft             Aircraft[]
  maintenanceLogs      MaintenanceLog[]
  telemetry            Telemetry[]
  schedulableResources SchedulableResource[]
  squawks              Squawk[]
  pilotMedicals        PilotMedical[]
  pilotCertificates    PilotCertificate[]
  flightReviewRecords  FlightReviewRecord[]
  aircraftCheckouts    AircraftCheckout[]

  @@map("organizations")
}

model Base {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  icaoCode       String       @map("icao_code")
  timezone       String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  userBases            UserBase[]
  homeAircraft         Aircraft[]
  bookings             Booking[]
  schedulableResources SchedulableResource[]

  @@unique([organizationId, icaoCode])
  @@index([organizationId])
  @@map("bases")
}

model UserBase {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseId String @map("base_id")
  base   Base   @relation(fields: [baseId], references: [id], onDelete: Cascade)

  @@unique([userId, baseId])
  @@index([userId])
  @@index([baseId])
  @@map("user_bases")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String       @map("password_hash")
  role           Role         @default(STUDENT)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  bookings            Booking[]
  userBases           UserBase[]
  bookingParticipants BookingParticipant[]
  pilotMedicals       PilotMedical[]
  pilotCertificates   PilotCertificate[]
  flightReviewRecords FlightReviewRecord[]
  aircraftCheckouts   AircraftCheckout[]
  checkoutSignoffs    AircraftCheckout[] @relation("CheckoutSignoff")

  @@index([organizationId])
  @@map("users")
}

model SchedulableResource {
  id             String                  @id @default(uuid())
  organizationId String                  @map("organization_id")
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  baseId         String                  @map("base_id")
  base           Base                    @relation(fields: [baseId], references: [id])
  kind           SchedulableResourceKind
  name           String
  isActive       Boolean                 @default(true) @map("is_active")
  aircraftId     String?                 @unique @map("aircraft_id")
  aircraft       Aircraft?               @relation(fields: [aircraftId], references: [id], onDelete: Cascade)

  bookings Booking[]

  @@index([organizationId])
  @@index([baseId])
  @@map("schedulable_resources")
}

model Aircraft {
  id                  String              @id @default(uuid())
  tailNumber          String              @map("tail_number")
  make                String
  model               String
  airworthinessStatus AirworthinessStatus @default(FLIGHT_READY) @map("airworthiness_status")
  hobbsHours          Decimal             @default(0) @map("hobbs_hours") @db.Decimal(12, 2)
  tachHours           Decimal             @default(0) @map("tach_hours") @db.Decimal(12, 2)
  organizationId      String              @map("organization_id")
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  homeBaseId          String              @map("home_base_id")
  homeBase            Base                @relation(fields: [homeBaseId], references: [id])
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  maintenanceLogs     MaintenanceLog[]
  telemetryRecords    Telemetry[]
  schedulableResource SchedulableResource?
  squawks             Squawk[]
  aircraftCheckouts   AircraftCheckout[]

  @@unique([organizationId, tailNumber])
  @@index([organizationId])
  @@map("aircraft")
}

model Booking {
  id        String        @id @default(uuid())
  startTime DateTime      @map("start_time")
  endTime   DateTime      @map("end_time")
  status    BookingStatus @default(SCHEDULED)
  createdAt DateTime      @default(now()) @map("created_at")

  dispatchedAt DateTime? @map("dispatched_at")
  completedAt  DateTime? @map("completed_at")
  cancelledAt  DateTime? @map("cancelled_at")

  hobbsOut Decimal? @map("hobbs_out") @db.Decimal(12, 2)
  hobbsIn  Decimal? @map("hobbs_in") @db.Decimal(12, 2)
  tachOut  Decimal? @map("tach_out") @db.Decimal(12, 2)
  tachIn   Decimal? @map("tach_in") @db.Decimal(12, 2)

  baseId String @map("base_id")
  base   Base   @relation(fields: [baseId], references: [id])

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  schedulableResourceId String              @map("schedulable_resource_id")
  schedulableResource   SchedulableResource @relation(fields: [schedulableResourceId], references: [id])

  participants BookingParticipant[]

  @@index([baseId])
  @@index([userId])
  @@index([schedulableResourceId])
  @@map("bookings")
}

model BookingParticipant {
  id             String                 @id @default(uuid())
  bookingId      String                 @map("booking_id")
  booking        Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId         String                 @map("user_id")
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           BookingParticipantRole
  organizationId String                 @map("organization_id")

  @@unique([bookingId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("booking_participants")
}

model Squawk {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  aircraftId      String       @map("aircraft_id")
  aircraft        Aircraft     @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  status          SquawkStatus @default(OPEN)
  groundsAircraft Boolean      @default(false) @map("grounds_aircraft")
  createdAt       DateTime     @default(now()) @map("created_at")
  clearedAt       DateTime?    @map("cleared_at")

  @@index([organizationId])
  @@index([aircraftId])
  @@map("squawks")
}

model PilotMedical {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  class          String       @map("class")
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@map("pilot_medicals")
}

model PilotCertificate {
  id               String       @id @default(uuid())
  userId           String       @map("user_id")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId   String       @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  certificateType  String       @map("certificate_type")
  identifier       String?
  expiresAt        DateTime?    @map("expires_at")
  createdAt        DateTime     @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@map("pilot_certificates")
}

model FlightReviewRecord {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  completedAt    DateTime     @map("completed_at")
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@map("flight_review_records")
}

model AircraftCheckout {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aircraftId         String    @map("aircraft_id")
  aircraft           Aircraft  @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  organizationId     String    @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiresAt          DateTime  @map("expires_at")
  signedOffByUserId  String?   @map("signed_off_by_user_id")
  signedOffBy        User?     @relation("CheckoutSignoff", fields: [signedOffByUserId], references: [id])
  createdAt          DateTime  @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@index([aircraftId])
  @@map("aircraft_checkouts")
}

model MaintenanceLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  data       Json

  aircraftId     String       @map("aircraft_id")
  aircraft       Aircraft     @relation(fields: [aircraftId], references: [id])
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("maintenance_logs")
}

model Telemetry {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  data       Json

  aircraftId     String       @map("aircraft_id")
  aircraft       Aircraft     @relation(fields: [aircraftId], references: [id])
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("telemetry")
}
